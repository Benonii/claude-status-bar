post_install() {
    cat <<'EOF'
==> claude-status-bar installed.

    1. Wire Claude Code hooks into ~/.claude/settings.json (per-user):
         claude-status-bar install
    2. Add the widget: right-click the panel -> Enter Edit Mode -> Add Widgets
       -> search "Claude Status Bar", then drag it where you want.
    3. Start a NEW Claude Code session (hooks are picked up at session start).

    Non-KDE fallback (system-tray icon; status in tooltip only):
         claude-status-bar &
EOF
}

post_upgrade() {
    post_install
}

pre_remove() {
    cat <<'EOF'
==> Remove the Claude Code hooks from your per-user config with:
         claude-status-bar uninstall
    (Do this before the binary is gone if you want it to clean settings.json.)
EOF
}
